# Required — get a key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Optional — override the default LLM (used only by the escalation agent)
# LLM_MODEL=deepseek/deepseek-v4-flash

# Optional — path to a real pET-28a(+) backbone FASTA/GenBank file
# Without this, plasmid assembly uses a placeholder sequence (Ns) with a warning.
# PET28A_BACKBONE_PATH=/path/to/pET-28a.fasta
